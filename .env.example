# BBH-AI Environment Variables Example
# Copy to .env and fill with your actual keys.

# LLM Providers (Required for AI Orchestration)
OPENAI_API_KEY="sk-proj-..."
ANTHROPIC_API_KEY="sk-ant-..."
GOOGLE_API_KEY="AIzaSy..."
DEEPSEEK_API_KEY="sk-..."

# Default AI Model (Used if not explicitly overridden in config)
LLM_DEFAULT_MODEL="claude-3-5-sonnet-20241022"

# CI/CD Notifications
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/T000.../B000.../XXX..."

# Jira Enterprise Integration
JIRA_URL="https://yourdomain.atlassian.net"
JIRA_EMAIL="security@yourdomain.com"
JIRA_TOKEN="ATATT3..."
JIRA_PROJECT_KEY="SEC"

# Optional: GitHub API token for self-updating/tool installation
GITHUB_TOKEN="ghp_..."

# Optional: Celery Distributed Engine (defaults to localhost Redis)
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/1"
